# Copy to .env and edit before running docker compose.
#
# Required (production will refuse weak defaults):
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please-use-12+chars
JWT_SECRET=please-generate-a-random-32+char-secret

# App
APP_PORT=8080
GIN_MODE=release
APP_ENV=production

# Database (local defaults)
DB_NAME=zai2api
DB_USER=postgres
DB_PASSWORD=postgres
DB_TIMEZONE=Asia/Shanghai

# Optional
# CORS_ALLOW_ORIGINS=https://admin.example.com
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
# ADMIN_MAX_BODY_BYTES=2097152
# IMAGE_MAX_BODY_BYTES=1048576
# OCR_MAX_BODY_BYTES=26214400
# UPSTREAM_MAX_RESPONSE_BYTES=10485760
# ALLOW_INSECURE_DEFAULTS=false
